# Copy this file to secrets.toml and fill in your Strava API app values.
# On Streamlit Community Cloud, paste these into the Secrets dashboard instead.

[strava]
client_id = "YOUR_CLIENT_ID"

# --- Option A: Cloudflare Worker (recommended for cloud) ---
# The Worker holds the client_secret server-side, so it's not needed here.
worker_url = "https://strava-proxy.ACCOUNT.workers.dev"
app_url = "https://YOUR_APP.streamlit.app"
# redirect_uri is auto-derived from worker_url when set

# --- Option B: Direct Strava API (local dev or without Worker) ---
# client_secret = "YOUR_CLIENT_SECRET"
# redirect_uri = "http://localhost:8501"
